{
  "name": "opensheetmusic",
  "version": "0.1.0",
  "description": "Cross-platform WYSIWYG sheet-music editor",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:comments": "node tools/check-no-comments.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@tauri-apps/api": "^1.6.0",
    "jspdf": "^2.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1",
    "vexflow": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@tauri-apps/cli": "^1.6.2",
    "@types/jsdom": "^28.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
